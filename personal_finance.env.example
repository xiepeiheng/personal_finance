# Copy this file to /opt/personal_finance/personal_finance.env and fill in real values.
# This file is on the SERVER ONLY — never committed to git.

# === Backend ===
SECRET_KEY=generate-a-random-secret-key
ALLOWED_HOSTS=your-domain.com,your-server-ip
CORS_ALLOWED_ORIGINS=https://your-domain.com

# === Frontend ===
VITE_BASE=/personal_finance/
VITE_API_BASE_URL=https://your-domain.com/personal_finance/api
